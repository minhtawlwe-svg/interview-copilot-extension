{
  "manifest_version": 3,
  "name": "Interview Copilot",
  "version": "1.1.0",
  "description": "AI interview helper in your side panel — capture the meeting tab in one click, speak, or type. Bring your own free Gemini key.",
  "permissions": ["sidePanel", "storage", "tabCapture", "tabs", "activeTab", "offscreen"],
  "host_permissions": ["https://interview-relay.vercel.app/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Open Interview Copilot" },
  "side_panel": { "default_path": "sidepanel.html" },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "commands": {
    "open-copilot": {
      "suggested_key": { "default": "Ctrl+Shift+U" },
      "description": "Open the Interview Copilot side panel"
    }
  }
}
